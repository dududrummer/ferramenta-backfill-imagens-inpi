# =============================================================================
# MODO DE EXECUÇÃO
# =============================================================================
# "remoto" (padrão): roda em outra máquina (WSL/Colab/Linux).
#   ClickHouse e `find` são acessados via SSH; imagens vão para LOCAL_STAGING e
#   sobem ao servidor por rsync. Requer SSH_HOST/SSH_USER/SSH_KEY.
# "servidor": roda diretamente NO servidor de produção.
#   Executa `clickhouse-client` e `find` localmente; escreve as imagens direto
#   em IMAGE_DIR. Rsync e SSH não são usados para operação — mas SSH_HOST,
#   SSH_USER e REMOTE_IMAGE_DIR ainda precisam estar preenchidos (o código os
#   lê na inicialização mesmo em modo servidor; use valores reais ou dummy).
MODO=remoto

# =============================================================================
# SSH / SERVIDOR (obrigatório em ambos os modos — veja nota acima)
# =============================================================================
SSH_HOST=seu.servidor.com
SSH_USER=deploy
SSH_KEY=~/.ssh/id_ed25519
SSH_PORT=22

# =============================================================================
# DIRETÓRIO DE IMAGENS
# =============================================================================
# MODO=servidor: IMAGE_DIR é o caminho local (no servidor) onde as imagens são
#   gravadas diretamente. REMOTE_IMAGE_DIR pode ter o mesmo valor.
# MODO=remoto: REMOTE_IMAGE_DIR é o caminho no servidor de destino (rsync).
#   IMAGE_DIR não precisa ser definido; LOCAL_STAGING é o diretório de staging
#   na máquina local.
IMAGE_DIR=
REMOTE_IMAGE_DIR=/var/neopi/bancoImagensINPI

# =============================================================================
# CLICKHOUSE
# =============================================================================
# Em MODO=remoto: clickhouse-client é executado via SSH no servidor.
# Em MODO=servidor: clickhouse-client é executado localmente.
CH_DATABASE=neopi

# =============================================================================
# TOR (uma porta SOCKS + uma CONTROL por instância; listas de mesmo tamanho)
# =============================================================================
TOR_HOST=127.0.0.1
TOR_SOCKS_PORTS=9050,9052,9054,9056
TOR_CONTROL_PORTS=9051,9053,9055,9057
TOR_CONTROL_PASSWORD=

# =============================================================================
# EXECUÇÃO
# =============================================================================
CONCURRENCY=8
RATE_PER_CIRCUIT=2
MAX_TENTATIVAS=3
# Requisições por circuito antes de rotacionar o IP (NEWNYM).
# O INPI aguenta ~20/IP; 18 dá margem.
MAX_REQ_POR_CIRCUITO=18
TIMEOUT_MS=30000

# =============================================================================
# CAMINHOS LOCAIS (MODO=remoto e MODO=servidor)
# =============================================================================
# LOCAL_STAGING: onde as imagens ficam antes do rsync (MODO=remoto).
#   Em MODO=servidor este valor é ignorado (imagens vão direto em IMAGE_DIR).
#   No WSL: use um caminho no FS nativo do Linux (ex.: ~/staging), NUNCA /mnt.
LOCAL_STAGING=./staging

# CATALOG_PATH: catálogo SQLite local que mantém o estado retomável.
#   No WSL: use um caminho no FS nativo do Linux, NUNCA /mnt.
CATALOG_PATH=./catalogo.sqlite

# Log de eventos em tempo real (uma linha por imagem; acompanhe com tail -f).
# Padrão: mesmo diretório do catálogo, arquivo eventos.log.
EVENTS_LOG=

# =============================================================================
# FLUSH / SINCRONIZAÇÃO
# =============================================================================
RSYNC_BATCH=2000
CH_UPDATE_BATCH=5000

# =============================================================================
# MARCAÇÃO tem_imagem NO CLICKHOUSE
# =============================================================================
# Por padrão desligado (0): n_url não é a sort key da tabela marcas, então
# cada UPDATE varre a tabela toda — pesado em produção.
# Use a reconciliação periódica (ver docs/uso.md) em vez de ligar isso.
# Para habilitar update inline: MARCAR_TEM_IMAGEM=1
MARCAR_TEM_IMAGEM=0

# =============================================================================
# OUTROS
# =============================================================================
# Hashes sha1 de placeholders "sem logo" do INPI (separados por vírgula).
# Preenchido após validação inicial.
PLACEHOLDER_HASHES=
