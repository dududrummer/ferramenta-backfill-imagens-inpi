# SSH / servidor
SSH_HOST=seu.servidor.com
SSH_USER=deploy
SSH_KEY=~/.ssh/id_ed25519
SSH_PORT=22
REMOTE_IMAGE_DIR=/var/neopi/bancoImagensINPI

# ClickHouse (acessado rodando clickhouse-client NO SERVIDOR via SSH; sem túnel)
CH_DATABASE=neopi

# Tor (uma porta SOCKS + uma CONTROL por instância; as listas devem ter o mesmo tamanho)
TOR_HOST=127.0.0.1
TOR_SOCKS_PORTS=9050,9052,9054,9056
TOR_CONTROL_PORTS=9051,9053,9055,9057
TOR_CONTROL_PASSWORD=

# Execução
CONCURRENCY=8
RATE_PER_CIRCUIT=2
MAX_TENTATIVAS=3
TIMEOUT_MS=30000
LOCAL_STAGING=./staging
CATALOG_PATH=./catalogo.sqlite
RSYNC_BATCH=2000
CH_UPDATE_BATCH=5000

# Hashes sha1 de placeholders "sem logo" do INPI (preenchido após validação; separados por vírgula)
PLACEHOLDER_HASHES=
