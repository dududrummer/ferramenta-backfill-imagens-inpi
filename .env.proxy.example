# Exemplo de .env para a re-raspagem em massa via PROXY (DataImpulse).
# Copie para .env e preencha. NÃO comite o .env (já está no .gitignore).

BACKEND=proxy

# Onde gravar (mesmo do modo Tor) — clickhouse-client roda no droplet por SSH.
MODO=remoto
SSH_HOST=68.183.113.157
SSH_USER=root
SSH_KEY=/root/.ssh/id_rsa
REMOTE_IMAGE_DIR=/data/bancoImagensINPI
CH_DATABASE=neopi

# ---- DataImpulse (pegue login/senha em "Proxy Access" no painel) ----
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_PROTOCOL=socks5            # socks5 (recomendado) ou http
PROXY_PASS=SUA_SENHA

# Usuário com STICKY SESSION: {session} é trocado pelo id (mesmo IP por lote; "newnym" = novo id).
# CONFIRME o formato exato no seu painel/docs da DataImpulse. Formatos comuns:
#   com país BR:  SEU_LOGIN__cr.br;sessid.{session}
#   sem país:     SEU_LOGIN;sessid.{session}
# Se quiser ROTATIVO (IP novo a cada conexão), use só o login, sem {session}.
PROXY_USER_TEMPLATE=SEU_LOGIN__cr.br;sessid.{session}

# Opcionais (o orquestrador sobrescreve por processo):
# CONCURRENCY=60
# PROXY_POOL_SIZE=100
# RATE_PER_CIRCUIT=1000
# MAX_REQ_POR_CIRCUITO=20
